@page "/services"
@using Microsoft.AspNetCore.Components.Web

@namespace RapportinoServer.Pages.Services

@inherits ListTypeServicePageBase

<PageTitle>Tipi di Servizio</PageTitle>

<div class="services-page">

    <div class="services-page__header">
        <h1 class="services-page__title">Tipi di Servizio</h1>

        <button class="btn btn--primary"
                @onclick="NewService"
                disabled="@IsLoading || IsDeleting">
            Nuovo Tipo
        </button>
    </div>

</div>

@if (IsLoading)
{
    <p class="services-page__loading">Caricamento...</p>
}
else if (LoadError is not null)
{
    <div class="alert alert--error">@LoadError</div>
}
else if (Services is null || !Services.Any())
{
    <p class="services-page__empty">Nessun tipo di servizio presente.</p>
}
else
{
    <table class="services-table">
        <thead>
        <tr>
            <th>Nome</th>
            <th class="services-table__actions-header"></th>
        </tr>
        </thead>

        <tbody>
        @foreach (var s in Services)
        {
            <tr>
                <td>@s.Name</td>

                <td class="services-table__actions">
                    <button class="btn btn--secondary btn--small"
                            @onclick="() => Edit(s.Id)"
                            disabled="@IsDeleting">
                        Modifica
                    </button>

                    <button class="btn btn--danger btn--small"
                            @onclick="() => ConfirmDelete(s.Id, s.Name)"
                            disabled="@IsDeleting">
                        Elimina
                    </button>
                </td>
            </tr>
        }
        </tbody>
    </table>
}
