@page "/technicians"
@namespace RapportinoServer.Pages.Technicians
@using Microsoft.AspNetCore.Components.Web
@inherits ListTechniciansPageBase

<PageTitle>Tecnici</PageTitle>

<div class="d-flex justify-content-between align-items-center mb-3">
    <h1 class="h2 title-section w-100">Tecnici</h1>
</div>

@if (IsLoading)
{
    <p>Caricamento...</p>
}
else if (LoadError is not null)
{
    <div class="alert alert-danger">@LoadError</div>
}
else if (Technicians is null || !Technicians.Any())
{
    <p class="mt-2">Nessun tecnico presente.</p>
}
else
{
    <table class="table table-striped">
        <thead>
        <tr>
            <th>Nome</th>
            <th class="text-end">Azioni</th>
        </tr>
        </thead>
        <tbody>
        @foreach (var t in Technicians)
        {
            <tr @key="t.Id">
                <td>@t.TechnicianName</td>
                <td class="text-end">
                    <button class="btn btn-sm btn-outline-secondary me-1" @onclick="() => Details(t.Id)" disabled="@IsDeleting">Dettagli</button>
                    <button class="btn btn-sm btn-warning me-1" @onclick="() => Edit(t.Id)" disabled="@IsDeleting">Modifica</button>
                    <button class="btn btn-sm btn-danger" @onclick="() => ConfirmDelete(t.Id, t.TechnicianName)" disabled="@IsDeleting">Elimina</button>
                </td>
            </tr>
        }
        </tbody>
    </table>
}