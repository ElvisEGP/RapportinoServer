@page "/clients/edit/{id:int}"
@using Microsoft.AspNetCore.Components.Web
@namespace RapportinoServer.Pages.Clients

@inherits ClientEditPageBase

<PageTitle>Modifica Cliente</PageTitle>

<div class="client-edit-page">

    <h1 class="client-edit__title">Modifica Cliente</h1>

    @if (IsLoading)
    {
        <p class="client-edit__loading">Caricamento...</p>
    }
    else if (LoadError is not null)
    {
        <div class="alert alert--error">@LoadError</div>
    }
    else if (Client is null)
    {
        <div class="alert alert--warning">Cliente non trovato.</div>
    }
    else
    {
        <EditForm EditContext="EditContext" OnValidSubmit="HandleValidSubmit" class="client-edit__form">
            <DataAnnotationsValidator />
            <ValidationSummary />

            <div class="form-grid">

                <!-- Nome Azienda -->
                <div class="form__group form__group--full">
                    <label class="form__label">Nome Azienda</label>
                    <InputText class="form__input" @bind-Value="Client.CompanyName" />
                    <ValidationMessage For="@(() => Client.CompanyName)" />
                </div>

                <!-- Indirizzo -->
                <div class="form__group form__group--large">
                    <label class="form__label">Indirizzo</label>
                    <InputText class="form__input" @bind-Value="Client.Address" />
                </div>

                <div class="form__group form__group--small">
                    <label class="form__label">Numero Civico</label>
                    <InputText class="form__input" @bind-Value="Client.NumberAddress" />
                </div>

                <div class="form__group form__group--medium">
                    <label class="form__label">Città</label>
                    <InputText class="form__input" @bind-Value="Client.City" />
                </div>

                <div class="form__group form__group--small">
                    <label class="form__label">CAP</label>
                    <InputText class="form__input" @bind-Value="Client.PostalCode" />
                </div>

                <div class="form__group form__group--small">
                    <label class="form__label">Provincia</label>
                    <InputText class="form__input" @bind-Value="Client.State" />
                </div>

                <div class="form__group form__group--small">
                    <label class="form__label">Nazione</label>
                    <InputText class="form__input" @bind-Value="Client.Country" />
                </div>

                <!-- Contatti -->
                <div class="form__group form__group--medium">
                    <label class="form__label">Telefono</label>
                    <InputText class="form__input" @bind-Value="Client.Phone" />
                </div>

                <div class="form__group form__group--large">
                    <label class="form__label">Email</label>
                    <InputText class="form__input" @bind-Value="Client.Email" />
                </div>

                <div class="form__group form__group--full">
                    <label class="form__label">Sito Web</label>
                    <InputText class="form__input" @bind-Value="Client.Website" />
                </div>

                <div class="form__group form__group--full">
                    <label class="form__label">Note</label>
                    <InputTextArea class="form__input" rows="3" @bind-Value="Client.Note" />
                </div>

                <!-- Data -->
                <div class="form__group form__group--medium">
                    <label class="form__label">Data</label>
                    <InputDate TValue="DateTime" class="form__input" @bind-Value="DataAsDateTime" />
                    <ValidationMessage For="@(() => DataAsDateTime)" />
                </div>

                <!-- Botões -->
                <div class="form__buttons">
                    <button type="button"
                            class="btn btn--secondary"
                            @onclick="GoBack"
                            disabled="@IsSaving">
                        Indietro
                    </button>

                    <button type="submit"
                            class="btn btn--primary btn--save"
                            disabled="@IsSaving">
                        <span class="loader loader--small" hidden="@(!IsSaving)"></span>
                        Salva Modifiche
                    </button>
                </div>

            </div>
        </EditForm>

        @if (!string.IsNullOrEmpty(ErrorMessage))
        {
            <div class="alert alert--error">@ErrorMessage</div>
        }
    }
</div>
