@page "/clients"
@namespace RapportinoServer.Pages.Clients
@using Microsoft.AspNetCore.Components.Web
@inherits ClientListPageBase

<PageTitle>Clienti</PageTitle>

<div class="mb-3">
    <h1 class="h2 title-section">Clienti</h1>

    <InputText class="form-control"
               @bind-Value="SearchTerm"
               @bind-Value:event="oninput" />
</div>

@if (IsLoading)
{
    <p>Caricamento...</p>
}
else if (LoadError is not null)
{
    <div class="alert alert-danger">@LoadError</div>
}
else if (Clients is null || !Clients.Any())
{
    <p class="mt-2">Nessun cliente presente.</p>
}
else
{
    <div class="mb-3">
        <InputText class="form-control"
                   @bind-Value="SearchTerm"
                   @bind-Value:event="oninput"
                   placeholder="Cerca cliente..." />
    </div>

    <table class="table table-striped">
        <thead>
        <tr>
            <th>Ragione Sociale</th>
            <th>Città</th>
            <th class="text-end">Azioni</th>
        </tr>
        </thead>
        <tbody>
        @foreach (var c in FilteredClients)
        {
            <tr @key="c.Id">
                <td>@c.CompanyName</td>
                <td>@c.City</td>
                <td class="text-end">
                    <button class="btn btn-sm btn-outline-secondary me-1" @onclick="() => Details(c.Id)">Dettagli</button>
                    <button class="btn btn-sm btn-warning me-1" @onclick="() => Edit(c.Id)">Modifica</button>
                    <button class="btn btn-sm btn-danger" @onclick="() => ConfirmDelete(c.Id, c.CompanyName)">Elimina</button>
                </td>
            </tr>
        }
        </tbody>
    </table>
}