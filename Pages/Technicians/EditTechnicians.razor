@page "/technicians/edit/{Id:int}"
@using Microsoft.AspNetCore.Components
@using Microsoft.AspNetCore.Components.Forms
@using Microsoft.AspNetCore.Components.Web
@namespace RapportinoServer.Pages.Technicians

@inherits EditTechniciansPageBase

<PageTitle>Modifica Tecnico</PageTitle>

<div class="technician-edit-page">

    @if (IsLoading)
    {
        <p class="technician-edit__loading">Caricamento...</p>
    }
    else if (LoadError is not null)
    {
        <div class="alert alert--error">@LoadError</div>
    }
    else if (Technician is null)
    {
        <div class="alert alert--warning">Tecnico non trovato.</div>
    }
    else
    {
        <h1 class="technician-edit__title">Modifica Tecnico</h1>

        <EditForm EditContext="EditContext" OnValidSubmit="HandleValidSubmit" class="technician-edit__form">
            <DataAnnotationsValidator />
            <ValidationSummary />

            <div class="form-grid">

                <!-- Nome -->
                <div class="form__group form__group--full">
                    <label class="form__label">Nome Tecnico</label>
                    <InputText class="form__input" @bind-Value="Technician.TechnicianName" />
                    <ValidationMessage For="@(() => Technician.TechnicianName)" />
                </div>

                <!-- Cognome -->
                <div class="form__group form__group--full">
                    <label class="form__label">Cognome</label>
                    <InputText class="form__input" @bind-Value="Technician.Surname" />
                    <ValidationMessage For="@(() => Technician.Surname)" />
                </div>

                <!-- Username -->
                <div class="form__group form__group--full">
                    <label class="form__label">Username</label>
                    <InputText class="form__input" @bind-Value="Technician.Username" />
                    <ValidationMessage For="@(() => Technician.Username)" />
                </div>

                <!-- Password -->
                <div class="form__group form__group--full">
                    <label class="form__label">Password</label>
                    <InputText type="password" class="form__input" @bind-Value="Technician.Password" />
                    <ValidationMessage For="@(() => Technician.Password)" />
                </div>

                <!-- Ruolo -->
                <div class="form__group form__group--full">
                    <label class="form__label">Ruolo</label>
                    <InputText class="form__input" @bind-Value="Technician.Role" />
                    <ValidationMessage For="@(() => Technician.Role)" />
                </div>

                <!-- Botões -->
                <div class="form__buttons">
                    <button class="btn btn--secondary" type="button" @onclick="Cancel" disabled="@IsSaving">
                        Annulla
                    </button>

                    <button class="btn btn--primary btn--save" type="submit" disabled="@IsSaving">
                        <span class="loader loader--small" hidden="@(!IsSaving)"></span>
                        Salva
                    </button>
                </div>

            </div>

            @if (!string.IsNullOrEmpty(ErrorMessage))
            {
                <div class="alert alert--error">@ErrorMessage</div>
            }
        </EditForm>
    }
</div>
