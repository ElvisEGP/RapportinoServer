@page "/technicians/details/{Id:int}"
@using Microsoft.AspNetCore.Components.Web
@namespace RapportinoServer.Pages.Technicians

@inherits TechnicianDetailsPageBase

<PageTitle>Dettagli Tecnico #@Technician?.Id</PageTitle>

<div class="technician-details-page">

    @if (IsLoading)
    {
        <p class="technician-details__loading">Caricamento...</p>
    }
    else if (LoadError is not null)
    {
        <div class="alert alert--error">@LoadError</div>
    }
    else if (Technician is null)
    {
        <div class="alert alert--warning">Tecnico non trovato.</div>
    }
    else
    {
        <!-- HEADER -->
        <div class="technician-details__header">
            <div>
                <h1 class="technician-details__title">Dettagli Tecnico</h1>
                <p class="technician-details__subtitle">#@Technician.Id - @Technician.TechnicianName</p>
            </div>

            <button class="btn btn--secondary" @onclick="BackToList">
                Torna ai tecnici
            </button>
        </div>

        <!-- GRID PRINCIPAL -->
        <div class="technician-details__grid">

            <!-- INFO TECNICHE -->
            <div class="info-card">
                <h3 class="info-card__title">Informazioni tecniche</h3>

                <p><strong>Nome:</strong> @Technician.TechnicianName</p>
                <p><strong>Cognome:</strong> @Technician.Surname</p>
                <p><strong>Username:</strong> @Technician.Username</p>
                <p><strong>Ruolo:</strong> @Technician.Role</p>
            </div>

            <!-- ACCESSO -->
            <div class="info-card">
                <h3 class="info-card__title">Accesso</h3>

                <p><strong>Password:</strong> ******</p>
                <p class="info-card__note">La password non è mostrata per motivi di sicurezza.</p>
            </div>

        </div>
    }
</div>
