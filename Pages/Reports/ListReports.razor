@page "/reports"
@using Microsoft.AspNetCore.Components.Web
@namespace RapportinoServer.Pages.Reports

@inherits ListReportsPageBase

<PageTitle>Lista dei Rapportini</PageTitle>

<div class="reports-page">

    <h1 class="reports-page__title">Rapportini</h1>

    @if (IsLoading)
    {
        <p class="reports-page__loading">Caricamento in corso...</p>
    }
    else if (LoadError is not null)
    {
        <div class="alert alert--error reports-page__error">@LoadError</div>
    }
    else if (Reports is null || !Reports.Any())
    {
        <p class="reports-page__empty">Nessun rapportino presente.</p>
    }
    else
    {
        <table class="reports-table">
            <thead>
                <tr>
                    <th>Cliente</th>
                    <th>Data</th>
                    <th>Technician</th>
                </tr>
            </thead>

            <tbody>
                @foreach (var r in Reports)
                {
                    <tr>
                        <td>@(string.IsNullOrWhiteSpace(r.Client?.CompanyName) ? "Cliente non specificato" : r.Client.CompanyName)</td>
                        <td>@r.Data.ToString("dd/MM/yyyy")</td>
                        <td>@r.TechnicianName</td>

                        <td class="reports-table__actions">
                            <button class="btn btn--outline btn--small"
                                    @onclick="() => GoToDetails(r.Id)"
                                    disabled="@IsDeleting">
                                Dettagli
                            </button>

                            <button class="btn btn--danger btn--small"
                                    @onclick="() => DeleteReport(r.Id)"
                                    disabled="@IsDeleting">
                                Elimina
                            </button>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    }
</div>
