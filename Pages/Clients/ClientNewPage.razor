@page "/clients/new"
@using Microsoft.AspNetCore.Components.Web
@using Microsoft.AspNetCore.Components.Forms
@namespace RapportinoServer.Pages.Clients
@inherits RapportinoServer.Pages.Clients.ClientNewPageBase

<PageTitle>Nuovo Cliente</PageTitle>

<div class="page-wrapper">

    <h1 class="page-title">Nuovo Cliente</h1>

    <EditForm EditContext="EditContext" OnValidSubmit="HandleValidSubmit" class="form">
        <DataAnnotationsValidator />
        <ValidationSummary />

        @if (!string.IsNullOrEmpty(ErrorMessage))
        {
            <div class="alert alert--error">@ErrorMessage</div>
        }

        <div class="form__grid">

            <!-- Ragione Sociale -->
            <div class="form__group form__group--full">
                <label class="form__label">Ragione Sociale</label>
                <InputText class="form__input" @bind-Value="Client.CompanyName" />
                <ValidationMessage For="@(() => Client.CompanyName)" />
            </div>

            <!-- Indirizzo -->
            <div class="form__group form__group--8">
                <label class="form__label">Indirizzo</label>
                <InputText class="form__input" @bind-Value="Client.Address" />
                <ValidationMessage For="@(() => Client.Address)" />
            </div>

            <!-- Numero Civico -->
            <div class="form__group form__group--4">
                <label class="form__label">Numero Civico</label>
                <InputText class="form__input" @bind-Value="Client.NumberAddress" />
                <ValidationMessage For="@(() => Client.NumberAddress)" />
            </div>

            <!-- Città -->
            <div class="form__group form__group--4">
                <label class="form__label">Città</label>
                <InputText class="form__input" @bind-Value="Client.City" />
                <ValidationMessage For="@(() => Client.City)" />
            </div>

            <!-- CAP -->
            <div class="form__group form__group--2">
                <label class="form__label">CAP</label>
                <InputText class="form__input" @bind-Value="Client.PostalCode" />
                <ValidationMessage For="@(() => Client.PostalCode)" />
            </div>

            <!-- Provincia -->
            <div class="form__group form__group--3">
                <label class="form__label">Provincia</label>
                <InputText class="form__input" @bind-Value="Client.State" />
                <ValidationMessage For="@(() => Client.State)" />
            </div>

            <!-- Nazione -->
            <div class="form__group form__group--3">
                <label class="form__label">Nazione</label>
                <InputText class="form__input" @bind-Value="Client.Country" />
                <ValidationMessage For="@(() => Client.Country)" />
            </div>

            <!-- Telefono -->
            <div class="form__group form__group--6">
                <label class="form__label">Telefono</label>
                <InputText class="form__input" @bind-Value="Client.Phone" />
                <ValidationMessage For="@(() => Client.Phone)" />
            </div>

            <!-- Email -->
            <div class="form__group form__group--6">
                <label class="form__label">Email</label>
                <InputText type="email" class="form__input" @bind-Value="Client.Email" />
                <ValidationMessage For="@(() => Client.Email)" />
            </div>

            <!-- Website -->
            <div class="form__group form__group--full">
                <label class="form__label">Sito Web</label>
                <InputText class="form__input" @bind-Value="Client.Website" />
                <ValidationMessage For="@(() => Client.Website)" />
            </div>

            <!-- Note -->
            <div class="form__group form__group--full">
                <label class="form__label">Note</label>
                <InputTextArea class="form__textarea textarea--note" rows="3" @bind-Value="Client.Note" />
            </div>

            <!-- Macchine -->
            <div class="form__group form__group--full form__machines">
                <div class="machines__header">
                    <h2 class="machines__title">Macchine del cliente</h2>

                    <button type="button"
                            class="btn btn--outline btn--small"
                            @onclick="AddMachine"
                            disabled="@IsSaving">
                        Aggiungi macchina
                    </button>
                </div>

                @for (var i = 0; i < Client.Machines.Count; i++)
                {
                    var machine = Client.Machines[i];

                    <div class="machine-card">
                        <div class="machine-card__body">

                            <div class="form__group form__group--5">
                                <label class="form__label">Modello</label>
                                <InputText class="form__input" @bind-Value="machine.Model" />
                            </div>

                            <div class="form__group form__group--5">
                                <label class="form__label">Matricola <span class="text--danger">*</span></label>
                                <InputText class="form__input" @bind-Value="machine.Serial" />
                            </div>

                            <div class="form__group form__group--2 machine-card__remove">
                                <button type="button"
                                        class="btn btn--danger btn--full"
                                        @onclick="() => RemoveMachine(machine)"
                                        disabled="@IsSaving">
                                    Rimuovi
                                </button>
                            </div>

                        </div>
                    </div>
                }
            </div>

            <!-- Botões -->
            <div class=" group--buttons form__group--full">
                
                <div class="form__group form__group--5 group--buttons">
                    <button type="submit" class="btn btn--primary btn--full btn--save" disabled="@IsSaving">
                        @if (IsSaving)
                        {
                            <span class="loader loader--small"></span>
                        }
                        Salva
                    </button>
                </div>
            </div>

        </div>
    </EditForm>
</div>
