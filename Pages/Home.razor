@page "/home"
@page "/"
@using Microsoft.AspNetCore.Components.Web
@using RapportinoServer.Data.Repositories
@using RapportinoServer.Models
@using RapportinoServer.Services
@namespace RapportinoServer.Pages
@inherits HomePageBase

<PageTitle>Home — Dashboard</PageTitle>

<div class="page-wrapper">

    <div class="page-header">
        <h1 class="page-title">Dashboard</h1>

        @if (AuthState.IsAuthenticated)
        {
            <p class="page-subtitle">
                <spam>Benvenuto, </spam>
                <spam class="name-user-session"><strong>@(AuthState.CurrentTechnician?.TechnicianName ?? AuthState.CurrentTechnician?.Username)</strong></spam>
            </p>
        }
    </div>

    @if (IsLoading)
    {
        <div class="loading-box">
            <div class="loader"></div>
            <span>Caricamento metriche…</span>
        </div>
    }
    else if (LoadError is not null)
    {
        <div class="alert alert-danger">@LoadError</div>
    }
    else if (Summary is not null)
    {
        <!-- GRID DE CARDS PRINCIPAIS -->
        <div class="grid grid-4 gap-xl">
            <div class="card stat-card">
                <div class="stat-content">
                    <div>
                        <p class="stat-label">Clienti</p>
                        <p class="stat-value">@Summary.ClientCount</p>
                    </div>
                    <div class="stat-icon text-primary"><i class="bi bi-building"></i></div>
                </div>
            </div>

            <div class="card stat-card">
                <div class="stat-content">
                    <div>
                        <p class="stat-label">Macchine</p>
                        <p class="stat-value">@Summary.MachineCount</p>
                    </div>
                    <div class="stat-icon text-green"><i class="bi bi-cpu"></i></div>
                </div>
            </div>

            <div class="card stat-card">
                <div class="stat-content">
                    <div>
                        <p class="stat-label">Rapportini totali</p>
                        <p class="stat-value">@Summary.ReportTotal</p>
                    </div>
                    <div class="stat-icon text-blue"><i class="bi bi-folder2-open"></i></div>
                </div>
            </div>

            <div class="card stat-card">
                <div class="stat-content">
                    <div>
                        <p class="stat-label">Questo mese</p>
                        <p class="stat-value">@Summary.ReportsThisMonth</p>

                        @if (Summary.MonthOverMonthDeltaPercent > 0)
                        {
                            <span class="badge badge-success">+@Summary.MonthOverMonthDeltaPercent% vs mese scorso</span>
                        }
                        else if (Summary.MonthOverMonthDeltaPercent < 0)
                        {
                            <span class="badge badge-neutral">@Summary.MonthOverMonthDeltaPercent% vs mese scorso</span>
                        }
                        else if (Summary.ReportsPreviousMonth == 0 && Summary.ReportsThisMonth > 0)
                        {
                            <span class="badge badge-success">Nuovo periodo</span>
                        }
                    </div>

                    <div class="stat-icon text-yellow"><i class="bi bi-graph-up-arrow"></i></div>
                </div>
            </div>
        </div>

        <!-- GRID SECUNDÁRIO -->
        <div class="grid grid-3 gap-xl mt-xl">
            <div class="card stat-card">
                <p class="stat-label">Tecnici</p>
                <p class="stat-value">@Summary.TechnicianCount</p>
            </div>

            <div class="card stat-card">
                <p class="stat-label">Tipi di servizio</p>
                <p class="stat-value">@Summary.TypeServiceCount</p>
            </div>

            <div class="card stat-card">
                <p class="stat-label">Ore lavorate (mese)</p>
                <p class="stat-value">@Summary.WorkedHoursThisMonthForUser <span class="unit">h</span></p>

            </div>
        </div>

        <!-- GRID PRINCIPAL (TABELA + GRÁFICO) -->
        <div class="grid grid-2 gap-xl mt-xl">

            <!-- TABELA -->
            <div class="card">
                <div class="card-header">
                    <span class="card-title"><i class="bi bi-clock-history text-primary"></i> Ultimi rapportini</span>
                    <a class="btn btn-outline" href="/reports">Vedi tutti</a>
                </div>

                <div class="card-body no-padding">
                    @if (Summary.RecentReports.Count == 0)
                    {
                        <p class="empty">Nessun rapportino presente.</p>
                    }
                    else
                    {
                        <div class="table-wrapper">
                            <table class="table table-striped">
                                <thead>
                                    <tr>
                                        <th>Cliente</th>
                                        <th>Data</th>
                                        <th>Seriale</th>
                                        <th>Tecnico</th>
                                        <th>Servizio</th>
                                        <th></th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var r in Summary.RecentReports)
                                    {
                                        <tr>
                                            <td>@(string.IsNullOrWhiteSpace(r.ClientName) ? "Cliente non specificato" : r.ClientName)</td>
                                            <td>@r.Data.ToString("dd/MM/yyyy")</td>
                                            <td>@r.Serial</td>
                                            <td>@r.TechnicianName</td>
                                            <td class="truncate" title="@r.ServiceType">@r.ServiceType</td>
                                            <td class="text-right">
                                                <a class="btn btn-link" href="@($"/reports/details/{r.Id}")">Dettaglio</a>
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    }
                </div>
            </div>

            <!-- GRÁFICO -->
            <div class="card">
                <div class="card-header">
                    <span class="card-title"><i class="bi bi-pie-chart text-primary"></i> Tipi di intervento (top)</span>
                </div>

                <div class="card-body">
                    @if (Summary.ServiceTypeBreakdown.Count == 0)
                    {
                        <p class="empty">Nessun dato da mostrare.</p>
                    }
                    else
                    {
                        @foreach (var slice in Summary.ServiceTypeBreakdown)
                        {
                            var pct = BarPercent(slice.ItemCount, MaxServiceSlice);

                            <div class="bar-item">
                                <div class="bar-label">
                                    <span class="truncate" title="@slice.Label">@slice.Label</span>
                                    <span class="text-muted">@slice.ItemCount</span>
                                </div>

                                <div class="progress">
                                    <div class="progress-bar" style="width:@pct%"></div>
                                </div>
                            </div>
                        }
                    }
                </div>
            </div>

        </div>
    }
</div>
