@page "/clients/details/{Id:int}"
@using Microsoft.AspNetCore.Components.Web
@namespace RapportinoServer.Pages.Clients

@inherits ClientDetailsPageBase

<PageTitle>Dettagli Cliente #@Client?.Id</PageTitle>

<div class="client-details-page">

    @if (IsLoading)
    {
        <p class="client-details__loading">Caricamento...</p>
    }
    else if (LoadError is not null)
    {
        <div class="alert alert--error">@LoadError</div>
    }
    else if (Client is null)
    {
        <div class="alert alert--warning">Cliente non trovato.</div>
    }
    else
    {
        <!-- HEADER -->
        <div class="client-details__header">
                <h1 class="client-details__title">Dettagli Cliente</h1>
        </div>

        <!-- GRID PRINCIPAL -->
        <div class="client-details__grid">

            <!-- INFO PRINCIPALI -->
            <div class="info-card">
                <h3 class="info-card__title">Informazioni principali</h3>

                <p><strong>Ragione sociale:</strong> @Client.CompanyName</p>
                <p><strong>Telefono:</strong> @Client.Phone</p>
                <p><strong>Email:</strong> @Client.Email</p>
                <p><strong>Sito web:</strong> @Client.Website</p>
                <p><strong>Data registrazione:</strong> @Client.Data.ToString("dd/MM/yyyy")</p>
            </div>

            <!-- INDIRIZZO -->
            <div class="info-card">
                <h3 class="info-card__title">Indirizzo</h3>
                <p>@Client.Address @Client.NumberAddress</p>
                <p>@Client.City</p>
                <p>@Client.PostalCode</p>
                <p>@Client.State</p>
                <p>@Client.Country</p>
            </div>

            <!-- NOTE -->
            <div class="info-card info-card--full">
                <h3 class="info-card__title">Note</h3>

                <p>@(!string.IsNullOrWhiteSpace(Client.Note)
                    ? Client.Note
                    : "Nessuna nota disponibile.")</p>
            </div>

            <!-- MACCHINE ASSOCIATE -->
            @if (Client.Machines?.Any() == true)
            {
                <div class="info-card info-card--full">
                    <h3 class="info-card__title">Macchine associate</h3>

                    <table class="client-machines-table">
                        <thead>
                            <tr>
                                <th>Modello</th>
                                <th>Matricola</th>
                                <th>ClientId</th>
                            </tr>
                        </thead>

                        <tbody>
                            @foreach (var machine in Client.Machines)
                            {
                                <tr>
                                    <td>@machine.Model</td>
                                    <td>@machine.Serial</td>
                                    <td>@machine.ClientId</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
        </div>
    }
</div>