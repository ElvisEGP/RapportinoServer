@page "/clients"
@namespace RapportinoServer.Pages.Clients
@using Microsoft.AspNetCore.Components.Web
@inherits ClientListPageBase

<PageTitle>Clienti</PageTitle>

<div class="clients-page">

    <h1 class="clients-page__title">Clienti</h1>

    <InputText class="form__input clients-page__search"
               @bind-Value="SearchTerm"
               @bind-Value:event="oninput" />
</div>

@if (IsLoading)
{
    <p class="clients-page__loading">Caricamento...</p>
}
else if (LoadError is not null)
{
    <div class="alert alert--error">@LoadError</div>
}
else if (Clients is null || !Clients.Any())
{
    <p class="clients-page__empty">Nessun cliente presente.</p>
}
else
{
    <div class="clients-page__search-wrapper">
        <InputText class="form__input clients-page__search"
                   @bind-Value="SearchTerm"
                   @bind-Value:event="oninput"
                   placeholder="Cerca cliente..." />
    </div>

    <table class="clients-table">
        <thead>
        <tr>
            <th>Ragione Sociale</th>
            <th>Città</th>
            <th class="azioni">Azioni</th>
        </tr>
        </thead>
        <tbody>
        @foreach (var c in FilteredClients)
        {
            <tr @key="c.Id">
                <td>@c.CompanyName</td>
                <td>@c.City</td>
                <td class="clients-table__actions">
                    <button class="btn btn--outline btn--small" @onclick="() => Details(c.Id)">Dettagli</button>
                    <button class="btn btn--secondary btn--small" @onclick="() => Edit(c.Id)">Modifica</button>
                    <button class="btn btn--danger btn--small" @onclick="() => ConfirmDelete(c.Id, c.CompanyName)">Elimina</button>
                </td>
            </tr>
        }
        </tbody>
    </table>
}
