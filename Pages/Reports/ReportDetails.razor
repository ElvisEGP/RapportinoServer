@page "/reports/details/{Id:int}"
@using Microsoft.AspNetCore.Components.Web
@namespace RapportinoServer.Pages.Reports

@inherits DetailsReportPageBase

<PageTitle>Dettagli Rapportino #@Report?.Id</PageTitle>

<!-- AÇÕES SUPERIORES -->
<div class="report-actions no-print">
    <button class="btn btn--secondary" @onclick="Back">
        Torna indietro
    </button>

    <button class="btn btn--primary" @onclick="PrintAsync">
        Stampa
    </button>

    <button class="btn btn--danger" @onclick="ShowPdfModal">
        Download PDF
    </button>
</div>

<!-- ERRO DE DOWNLOAD -->
@if (!string.IsNullOrEmpty(DownloadError))
{
    <div class="alert alert--error">@DownloadError</div>
}

<!-- MODAL PDF -->
@if (ShowDownloadModal)
{
    <div class="modal-overlay">
        <div class="modal">
            <h4 class="modal__title">Download PDF</h4>
            <p>Conferma per generare e scaricare il rapportino in formato PDF:</p>

            <div class="modal__actions">
                <button class="btn btn--secondary" @onclick="ClosePdfModal">Annulla</button>
                <button class="btn btn--danger" @onclick="ConfirmDownloadPdf">Scarica Ora</button>
            </div>
        </div>
    </div>
}

<!-- LOADING -->
@if (IsLoading)
{
    <div class="loading">
        <div class="loader"></div>
        <p>Caricamento...</p>
    </div>
}
else if (LoadError is not null)
{
    <div class="alert alert--error">@LoadError</div>
    <button class="btn btn--secondary" @onclick="Back">Torna indietro</button>
}
else if (Report is null)
{
    <div class="alert alert--warning">Rapportino non trovato.</div>
    <button class="btn btn--secondary" @onclick="Back">Torna indietro</button>
}
else
{
    <div class="report">

        <!-- HEADER -->
        <div class="report__header">
            <h1 class="report__title">Rapportino di Intervento</h1>

            <div class="report__meta">
                <div><strong>N°:</strong> #@Report.Id</div>
                <div><strong>Data:</strong> @Report.Data.ToString("dd/MM/yyyy")</div>
            </div>
        </div>

        <!-- INFO PRINCIPAL -->
        <div class="report__info-section">
            <div class="info-box">
                <h3 class="info-box__title">Informazioni Macchina</h3>
                <div class="info-row"><span class="info-label">Modello:</span> @Report.Model</div>
                <div class="info-row"><span class="info-label">Seriale:</span> @Report.Serial</div>
                <div class="info-row"><span class="info-label">Tecnico:</span> @Report.TechnicianName</div>
            </div>

            <div class="info-box">
                <h3 class="info-box__title">Dettagli Servizio</h3>
                <div class="info-row"><span class="info-label">Tipo:</span> @Report.ServiceType</div>
                <div class="info-row"><span class="info-label">Email:</span> @Report.Email</div>
            </div>
        </div>

        <!-- DESCRIÇÃO -->
        <div class="report__description">
            <span class="description__title">Rapporto Generale:</span>
            <div class="description__box">@Report.ReportDescription</div>
        </div>

        <!-- CHECK SICUREZZA -->
        @if (Report.SafetyDevicesCheck)
        {
            <div class="safety safety--ok">
                <strong>[X] Macchina con tutti dispositivi di sicurezza presenti e funzionanti</strong>
            </div>
        }
        else
        {
            <div class="safety safety--fail">
                <strong>[ ] Macchina con tutti dispositivi di sicurezza presenti e funzionanti</strong>
            </div>
        }

        <!-- MATERIALI -->
        <div class="report__info-section">
            <div class="info-box">
                <h3 class="info-box__title">Materiale Sostituito</h3>
                <div class="info-text">@Report.ChangedMaterial</div>
            </div>

            <div class="info-box">
                <h3 class="info-box__title">Materiale Ordinato</h3>
                <div class="info-text">@Report.OrderedMaterial</div>
            </div>
        </div>

        <!-- ORE DI LAVORO -->
        <h3 class="worklog__title">Ore di Lavoro</h3>

        <table class="worklog-table">
            <thead>
                <tr>
                    <th>Data</th>
                    <th>Tempo Impiegato</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var log in Report.WorkLogs)
                {
                    <tr>
                        <td>@log.WorkedDate.ToString("dd/MM/yyyy")</td>
                        <td>@log.WorkedTime.ToString(@"hh\:mm")</td>
                    </tr>
                }
            </tbody>
        </table>

        <!-- FIRME -->
        <div class="signatures">
            <div class="signature">
                @if (!string.IsNullOrWhiteSpace(Report.ClientSignature))
                {
                    <img src="@Report.ClientSignature" class="signature__image" alt="Firma Cliente" />
                }
                else
                {
                    <div class="signature__placeholder">(Nessuna firma cliente)</div>
                }
                <div class="signature__label">Firma Cliente</div>
            </div>

            <div class="signature">
                @if (!string.IsNullOrWhiteSpace(Report.TechnicianSignature))
                {
                    <img src="@Report.TechnicianSignature" class="signature__image" alt="Firma Tecnico" />
                }
                else
                {
                    <div class="signature__placeholder">(Nessuna firma tecnico)</div>
                }
                <div class="signature__label">Firma Tecnico</div>
            </div>
        </div>

    </div>
}
