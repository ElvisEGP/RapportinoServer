@page "/services/edit/{id:int}"
@using Microsoft.AspNetCore.Components.Web
@using Microsoft.AspNetCore.Components.Forms

@namespace RapportinoServer.Pages.Services

@inherits EditTypeServicePageBase

<PageTitle>Modifica Tipo di Servizio</PageTitle>

<div class="service-edit-page">

    @if (IsLoading)
    {
        <p class="service-edit__loading">Caricamento...</p>
    }
    else if (LoadError is not null)
    {
        <div class="alert alert--error">@LoadError</div>
    }
    else if (Service is null)
    {
        <div class="alert alert--warning">Tipo di servizio non trovato.</div>
    }
    else
    {
        <h1 class="service-edit__title">Modifica Tipo di Servizio</h1>

        <EditForm EditContext="EditContext" OnValidSubmit="HandleValidSubmit" class="service-edit__form">
            <DataAnnotationsValidator />
            <ValidationSummary />

            <div class="form-grid">

                <!-- Nome -->
                <div class="form__group form__group--full">
                    <label class="form__label">Nome</label>
                    <InputText class="form__input" @bind-Value="Service.Name" />
                    <ValidationMessage For="@(() => Service.Name)" />
                </div>

                <!-- Botões -->
                <div class="form__buttons">
                    <button class="btn btn--secondary"
                            type="button"
                            @onclick="Cancel"
                            disabled="@IsSaving">
                        Annulla
                    </button>

                    <button class="btn btn--primary btn--save"
                            type="submit"
                            disabled="@IsSaving">
                        <span class="loader loader--small" hidden="@(!IsSaving)"></span>
                        Salva
                    </button>
                </div>

            </div>

            @if (!string.IsNullOrEmpty(ErrorMessage))
            {
                <div class="alert alert--error">@ErrorMessage</div>
            }
        </EditForm>
    }
</div>
