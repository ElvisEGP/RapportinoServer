@using Microsoft.Extensions.Logging
@inject IJSRuntime JS
@inject ILogger<NavMenu> Logger

<header class="nav">
    <nav class="nav__container">

        <button class="nav__toggle" aria-label="Abrir menu" aria-expanded="false">
            <span></span><span></span><span></span>
        </button>

        <ul class="nav__menu">

            <li class="nav__item">
                <NavLink href="/home" class="nav__link">Home</NavLink>
            </li>

            <li class="nav__item">
                <NavLink href="/clients/new" class="nav__link">Nuovo Cliente</NavLink>
            </li>

            <li class="nav__item">
                <NavLink href="/reports/new" class="nav__link">Nuovo Rapportino</NavLink>
            </li>

            <li class="nav__item">
                <NavLink href="/reports" Match="NavLinkMatch.All" class="nav__link">Lista di Rapportini</NavLink>
            </li>

            

            @if (AuthState.IsAdmin)
            {
                <li class="nav__item">
                    <span class="nav__link"> | </span>
                </li>

                <li class="nav__item">
                    <NavLink href="/technicians/new" class="nav__link">Nuovo Tecnico</NavLink>
                </li>
                

                <li class="nav__item">
                    <NavLink href="/services/new" class="nav__link">Nuovo Tipo di Servizio</NavLink>
                </li>

                <li class="nav__item">
                    <NavLink href="/clients" Match="NavLinkMatch.All" class="nav__link">Lista dei Clienti</NavLink>
                </li>

                <li class="nav__item">
                    <NavLink href="/technicians" Match="NavLinkMatch.All" class="nav__link">Lista dei Tecnici</NavLink>
                </li>

                <li class="nav__item">
                    <NavLink href="/services" Match="NavLinkMatch.All" class="nav__link">Lista dei Servizi</NavLink>
                </li>
            }

            @if (AuthState.IsAuthenticated)
            {
                <li class="nav__item">
                    <span class="nav__link"> | </span>
                </li>
                <li class="nav__item">
                    <button class="nav__link nav__link--logout" @onclick="Logout">Logout</button>
                </li>
            }

        </ul>

        <div class="nav__user">
            Connesso: @AuthState.CurrentTechnician?.Username
        </div>

    </nav>
</header>





@code {
    [Inject] private RapportinoServer.Services.AuthStateService AuthState { get; set; } = default!;
    [Inject] private NavigationManager Nav { get; set; } = default!;

    private void Logout()
    {
        AuthState.SignOut();
        Nav.NavigateTo("/login", forceLoad: false);
    }
    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            try
            {
                await JS.InvokeVoidAsync("initNavMenu");
            }
            catch (Exception ex)
            {
                Logger.LogWarning(ex, "Falha ao inicializar o menu de navegação via JS interop.");
            }
        }
    }
}
