@page "/reports/new"

@using Microsoft.AspNetCore.Components.Web
@using Microsoft.AspNetCore.Components.Forms
@namespace RapportinoServer.Pages.Reports
@inherits RapportinoServer.Pages.Reports.NewReportPageBase

<PageTitle>Nuovo Rapportino</PageTitle>

<div class="report-page">

    <h1 class="report-page__title">Nuovo Rapportino</h1>

    <EditForm EditContext="EditContext" OnValidSubmit="HandleValidSubmit" FormName="NewReportForm" class="report-form">
        <DataAnnotationsValidator />
        <ValidationSummary />

        @if (!string.IsNullOrEmpty(SaveError))
        {
            <div class="alert alert--error">@SaveError</div>
        }

        <div class="form__grid">

            <!-- CLIENTE -->
            <div class="form__group form__group--full position-relative">
                <label class="form__label">Cliente (Azienda)</label>

                <input class="form__input"
                       value="@ClientSearch"
                       @oninput="OnClientSearchInput"
                       @onfocus="ShowClientsList"
                       @onkeydown:escape="HideClientsList" />

                @if (ShowClientList && FilteredClients.Any())
                {
                    <ul class="dropdown-list">
                        @foreach (var c in FilteredClients)
                        {
                            <li class="dropdown-list__item"
                                @onmousedown:preventDefault="true"
                                @onmousedown="@(() => SelectClient(c))">
                                @c.CompanyName (@c.City)
                            </li>
                        }
                    </ul>
                }

                @if (SelectedClient is null)
                {
                    <button type="button"
                            class="btn btn--outline btn--small"
                            @onclick="NewClient">
                        Nuovo Cliente
                    </button>
                }
                else
                {
                    <p class="text--success">
                        Cliente selezionato: @SelectedClient.CompanyName (@SelectedClient.City)
                    </p>
                }
            </div>

            <!-- EMAIL -->
            <div class="form__group form__group--6">
                <label class="form__label">Email</label>
                <InputText type="email"
                           class="form__input"
                           @bind-Value="Report.Email" />
                <ValidationMessage For="@(() => Report.Email)" />
            </div>

            <!-- SERIALE -->
            <div class="form__group form__group--6">
                <label class="form__label">Seriale</label>

                @if (FilteredMachines.Any())
                {
                    <InputSelect class="form__input"
                                 @bind-Value="SelectedSerial"
                                 @bind-Value:after="OnSerialSelected">
                        <option value="">Seleziona seriale...</option>
                        @foreach (var serial in FilteredSerials)
                        {
                            <option value="@serial">@serial</option>
                        }
                    </InputSelect>
                }
                else
                {
                    <InputText class="form__input"
                               @bind-Value="Report.Serial" />
                    <ValidationMessage For="@(() => Report.Serial)" />
                }
            </div>

            <!-- MODELLO -->
            <div class="form__group form__group--6">
                <label class="form__label">Modello</label>
                <InputText class="form__input"
                           @bind-Value="Report.Model"
                           readonly="@(!string.IsNullOrWhiteSpace(SelectedSerial))" />
                <ValidationMessage For="@(() => Report.Model)" />
            </div>

            <!-- TECNICO -->
            <div class="form__group form__group--6">
                <label class="form__label">Tecnico</label>
                <InputSelect class="form__input" @bind-Value="Report.TechnicianName">
                    <option value="">Seleziona tecnico...</option>
                    @foreach (var t in Technicians)
                    {
                        <option value="@t.TechnicianName">@t.TechnicianName</option>
                    }
                </InputSelect>
                <ValidationMessage For="@(() => Report.TechnicianName)" />
            </div>

            <!-- SERVIZIO -->
            <div class="form__group form__group--6">
                <label class="form__label">Tipo di Servizio</label>
                <InputSelect class="form__input" @bind-Value="Report.ServiceType">
                    <option value="">Seleziona servizio...</option>
                    @foreach (var s in Services)
                    {
                        <option value="@s.Name">@s.Name</option>
                    }
                </InputSelect>
                <ValidationMessage For="@(() => Report.ServiceType)" />
            </div>

            <!-- RAPPORTO GENERALE -->
            <div class="form__group form__group--full">
                <label class="form__label">Rapporto Generale</label>
                <InputTextArea class="form__textarea"
                               rows="8"
                               @bind-Value="Report.ReportDescription" />
                <ValidationMessage For="@(() => Report.ReportDescription)" />
            </div>

            <!-- SICUREZZA -->
            <div class="form__group form__group--full">
                <label class="checkbox">
                    <InputCheckbox class="checkbox__input" @bind-Value="Report.SafetyDevicesCheck" />
                    <span class="checkbox__label">
                        Macchina con tutti dispositivi di siccurezza presente e funzionante
                    </span>
                </label>
            </div>

            <!-- MATERIALI -->
            <div class="form__group form__group--6">
                <label class="form__label">Materiale Sostituito</label>
                <InputTextArea class="form__textarea"
                               rows="6"
                               @bind-Value="Report.ChangedMaterial" />
            </div>

            <div class="form__group form__group--6">
                <label class="form__label">Materiale Ordinato / Preventivale</label>
                <InputTextArea class="form__textarea"
                               rows="6"
                               @bind-Value="Report.OrderedMaterial" />
            </div>

            <!-- ORE DI LAVORO -->
            <div class="form__group form__group--full">
                <h5 class="form__subtitle">Ore di Lavoro</h5>

                <table class="worklog-table">
                    <thead>
                        <tr>
                            <th>Data</th>
                            <th>Ore</th>
                            <th></th>
                        </tr>
                    </thead>

                    <tbody>
                        @for (int i = 0; i < Report.WorkLogs.Count && i < logHours.Count && i < logMinutes.Count; i++)
                        {
                            var index = i;
                            var log = Report.WorkLogs[index];

                            <tr>
                                <td>
                                    <InputDate class="form__input" @bind-Value="log.WorkedDate" />
                                </td>

                                <td>
                                    <div class="worklog-time">
                                        <select class="form__input worklog-time__select"
                                                value="@logHours[index]"
                                                @onchange="@(e => SetLogHour(index, e.Value?.ToString()))">
                                            @for (int h = 0; h < 24; h++)
                                            {
                                                <option value="@h">@h.ToString("00")</option>
                                            }
                                        </select>

                                        <select class="form__input worklog-time__select"
                                                value="@logMinutes[index]"
                                                @onchange="@(e => SetLogMinute(index, e.Value?.ToString()))">
                                            @for (int m = 0; m < 60; m += 5)
                                            {
                                                <option value="@m">@m.ToString("00")</option>
                                            }
                                        </select>
                                    </div>
                                </td>

                                <td>
                                    <button type="button"
                                            class="btn btn--danger btn--small"
                                            @onclick="@(() => RemoveLogAt(index))"
                                            disabled="@IsSaving">
                                        <i class="add--line"> - </i>
                                    </button>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>

                <button type="button"
                        class="btn btn--outline btn--small"
                        @onclick="AddLog"
                        disabled="@IsSaving">
                    <i class="bi bi-plus"> Aggiungi riga</i>
                </button>
            </div>

            <!-- FIRMA CLIENTE -->
            <div class="form__group form__group--full">
                <label class="form__label form__label--bold">Firma Cliente</label>

                <InputFile OnChange="HandleClientSignatureUpload"
                        accept="image/*"
                        class="form__input" />

                @if (!string.IsNullOrWhiteSpace(Report.ClientSignature))
                {
                    <div class="signature-box" style="margin-top:10px;">
                        <img src="@Report.ClientSignature"
                            style="max-width:300px; border:1px solid #ccc; border-radius:8px;" />
                    </div>
                }
            </div>

            <!-- FIRMA TECNICO -->
            <div class="form__group form__group--full">
                <label class="form__label form__label--bold">Firma Tecnico</label>

                <InputFile OnChange="HandleTechSignatureUpload"
                        accept="image/*"
                        class="form__input" />

                @if (!string.IsNullOrWhiteSpace(Report.TechnicianSignature))
                {
                    <div class="signature-box" style="margin-top:10px;">
                        <img src="@Report.TechnicianSignature"
                            style="max-width:300px; border:1px solid #ccc; border-radius:8px;" />
                    </div>
                }
            </div>

    </EditForm>
</div>