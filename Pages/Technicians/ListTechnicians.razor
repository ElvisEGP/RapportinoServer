@page "/technicians"
@namespace RapportinoServer.Pages.Technicians
@using Microsoft.AspNetCore.Components.Web
@inherits ListTechniciansPageBase

<PageTitle>Tecnici</PageTitle>

<div class="technicians-page">

    <h1 class="technicians-page__title">Tecnici</h1>

</div>

@if (IsLoading)
{
    <p class="technicians-page__loading">Caricamento...</p>
}
else if (LoadError is not null)
{
    <div class="alert alert--error">@LoadError</div>
}
else if (Technicians is null || !Technicians.Any())
{
    <p class="technicians-page__empty">Nessun tecnico presente.</p>
}
else
{
    <table class="technicians-table">
        <thead>
        <tr>
            <th>Nome</th>
            <th class="technicians-table__actions-header">Azioni</th>
        </tr>
        </thead>

        <tbody>
        @foreach (var t in Technicians)
        {
            <tr @key="t.Id">
                <td>@t.TechnicianName</td>

                <td class="technicians-table__actions">
                    <button class="btn btn--outline btn--small"
                            @onclick="() => Details(t.Id)"
                            disabled="@IsDeleting">
                        Dettagli
                    </button>

                    <button class="btn btn--secondary btn--small"
                            @onclick="() => Edit(t.Id)"
                            disabled="@IsDeleting">
                        Modifica
                    </button>

                    <button class="btn btn--danger btn--small"
                            @onclick="() => ConfirmDelete(t.Id, t.TechnicianName)"
                            disabled="@IsDeleting">
                        Elimina
                    </button>
                </td>
            </tr>
        }
        </tbody>
    </table>
}
