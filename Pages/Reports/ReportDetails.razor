@page "/reports/details/{Id:int}"
@using Microsoft.AspNetCore.Components.Web
@namespace RapportinoServer.Pages.Reports

@inherits DetailsReportPageBase

<PageTitle>Dettagli Rapportino #@Report?.Id</PageTitle>

<style>
    .report-container {
        background: #fff;
        padding: 20px;
        box-shadow: 0 0 10px rgba(0,0,0,0.1);
        max-width: 800px;
        margin: 10px auto;
        font-family: Arial, sans-serif;
        font-size: 13px;
    }

    .report-header {
        border-bottom: 2px solid #333;
        margin-bottom: 15px;
        padding-bottom: 5px;
        display: flex;
        justify-content: space-between;
        align-items: center;
    }

    .report-title {
        font-size: 20px;
        font-weight: bold;
        text-transform: uppercase;
        margin: 0;
    }

    .info-section {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 15px;
        margin-bottom: 15px;
    }

    .info-box {
        border: 1px solid #ddd;
        padding: 10px;
        border-radius: 4px;
    }

    .info-box h3 {
        font-size: 14px;
        margin-top: 0;
        border-bottom: 1px solid #eee;
        padding-bottom: 3px;
        color: #555;
    }

    .detail-row {
        margin-bottom: 3px;
    }

    .detail-label {
        font-weight: bold;
        color: #333;
    }

    .description-section {
        margin-bottom: 15px;
    }

    .description-box {
        border: 1px solid #ddd;
        padding: 10px;
        border-radius: 4px;
        min-height: 60px;
        white-space: pre-wrap;
        background: #f9f9f9;
    }

    .description-title {
        font-weight: bold;
        margin-bottom: 3px;
        display: block;
    }

    .table-hours {
        width: 100%;
        border-collapse: collapse;
        margin-bottom: 15px;
    }

    .table-hours th, .table-hours td {
        border: 1px solid #ddd;
        padding: 8px;
        text-align: left;
    }

    .table-hours th {
        background-color: #f2f2f2;
    }

    .signatures-section {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 20px;
        margin-top: 20px;
    }

    .signature-box {
        text-align: center;
    }

    .signature-image {
        max-width: 100%;
        height: auto;
        border-bottom: 1px solid #333;
        margin-bottom: 5px;
        max-height: 100px;
    }

    .signature-label {
        font-weight: bold;
        font-size: 13px;
    }

    .no-print {
        display: flex;
        gap: 10px;
        justify-content: center;
        margin-bottom: 20px;
    }

    .custom-modal-overlay {
        position: fixed;
        top: 0;
        left: 0;
        width: 100%;
        height: 100%;
        background: rgba(0,0,0,0.5);
        display: flex;
        align-items: center;
        justify-content: center;
        z-index: 1000;
    }

    .custom-modal-content {
        background: white;
        padding: 30px;
        border-radius: 8px;
        text-align: center;
        box-shadow: 0 4px 15px rgba(0,0,0,0.2);
        max-width: 400px;
        width: 90%;
    }

    @@media print {
        .no-print, .custom-modal-overlay {
            display: none !important;
        }

        body {
            background: none;
            margin: 0;
            padding: 0;
        }

        .report-container {
            box-shadow: none;
            margin: 0;
            padding: 0;
            max-width: 100%;
            width: 100%;
            border: none;
        }

        @@page {
            size: A4;
            margin: 10mm;
        }

        /* Forçar quebra de página se necessário, mas tentamos manter em uma */
        .report-container {
            page-break-inside: avoid;
        }
    }
</style>

<div class="no-print mt-4">
    <button class="btn btn-secondary" @onclick="Back">
        <i class="bi bi-arrow-left"></i> Torna indietro
    </button>
    <button class="btn btn-primary" @onclick="PrintAsync">
        <i class="bi bi-printer"></i> Stampa
    </button>
    <button class="btn btn-danger" @onclick="ShowPdfModal">
        <i class="bi bi-file-earmark-pdf"></i> Download PDF
    </button>
</div>

@if (!string.IsNullOrEmpty(DownloadError))
{
    <div class="alert alert-danger mt-3">@DownloadError</div>
}

@if (ShowDownloadModal)
{
    <div class="custom-modal-overlay">
        <div class="custom-modal-content">
            <h4 class="mb-3">Download PDF</h4>
            <p>Conferma per generare e scaricare il rapportino in formato PDF:</p>
            <div class="d-flex justify-content-center gap-2 mt-4">
                <button class="btn btn-secondary" @onclick="ClosePdfModal">Annulla</button>
                <button class="btn btn-danger" @onclick="ConfirmDownloadPdf">Scarica Ora</button>
            </div>
        </div>
    </div>
}

@if (IsLoading)
{
    <div class="text-center mt-5">
        <div class="spinner-border" role="status">
            <span class="visually-hidden">Caricamento...</span>
        </div>
        <p class="mt-2">Caricamento...</p>
    </div>
}
else if (LoadError is not null)
{
    <div class="container mt-4">
        <div class="alert alert-danger">@LoadError</div>
        <button class="btn btn-secondary" @onclick="Back">Torna indietro</button>
    </div>
}
else if (Report is null)
{
    <div class="container mt-4">
        <div class="alert alert-warning">Rapportino non trovato.</div>
        <button class="btn btn-secondary" @onclick="Back">Torna indietro</button>
    </div>
}
else
{
    <div class="report-container">
        <div class="report-header">
            <h1 class="report-title">Rapportino di Intervento</h1>
            <div class="text-end">
                <div><strong>N°:</strong> #@Report.Id</div>
                <div><strong>Data:</strong> @Report.Data.ToString("dd/MM/yyyy")</div>
            </div>
        </div>

        <div class="info-section">
            <div class="info-box">
                <h3>Informazioni Macchina</h3>
                <div class="detail-row"><span class="detail-label">Modello:</span> @Report.Model</div>
                <div class="detail-row"><span class="detail-label">Seriale:</span> @Report.Serial</div>
                <div class="detail-row"><span class="detail-label">Tecnico:</span> @Report.TechnicianName</div>
            </div>
            <div class="info-box">
                <h3>Dettagli Servizio</h3>
                <div class="detail-row"><span class="detail-label">Tipo:</span> @Report.ServiceType</div>
                <div class="detail-row"><span class="detail-label">Email:</span> @Report.Email</div>
            </div>
        </div>

        <div class="description-section">
            <span class="description-title">Rapporto Generale:</span>
            <div class="description-box">@Report.ReportDescription</div>
        </div>

        @if (Report.SafetyDevicesCheck)
        {
            <div class="mb-3">
                <strong>[X] Macchina con tutti dispositivi di siccurezza presente e funzionante</strong>
            </div>
        }
        else
        {
            <div class="mb-3 text-danger">
                <strong>[ ] Macchina con tutti dispositivi di siccurezza presente e funzionante</strong>
            </div>
        }

        <div class="info-section">
            <div class="info-box">
                <h3>Materiale Sostituito</h3>
                <div style="white-space: pre-wrap;">@Report.ChangedMaterial</div>
            </div>
            <div class="info-box">
                <h3>Materiale Ordinato</h3>
                <div style="white-space: pre-wrap;">@Report.OrderedMaterial</div>
            </div>
        </div>

        <h3 style="font-size: 18px; margin-bottom: 10px;">Ore di Lavoro</h3>
        <table class="table-hours">
            <thead>
                <tr>
                    <th>Data</th>
                    <th>Tempo Impiegato</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var log in Report.WorkLogs)
                {
                    <tr>
                        <td>@log.WorkedDate.ToString("dd/MM/yyyy")</td>
                        <td>@log.WorkedTime.ToString(@"hh\:mm")</td>
                    </tr>
                }
            </tbody>
        </table>

        <div class="signatures-section">
            <div class="signature-box">
                @if (!string.IsNullOrWhiteSpace(Report.ClientSignature))
                {
                    <img src="@Report.ClientSignature" class="signature-image" alt="Firma Cliente" />
                }
                else
                {
                    <div style="height: 100px; display: flex; align-items: center; justify-content: center; border-bottom: 1px solid #333; margin-bottom: 5px; color: #999; font-style: italic;">
                        (Nessuna firma cliente)
                    </div>
                }
                <div class="signature-label">Firma Cliente</div>
            </div>
            <div class="signature-box">
                @if (!string.IsNullOrWhiteSpace(Report.TechnicianSignature))
                {
                    <img src="@Report.TechnicianSignature" class="signature-image" alt="Firma Tecnico" />
                }
                else
                {
                    <div style="height: 100px; display: flex; align-items: center; justify-content: center; border-bottom: 1px solid #333; margin-bottom: 5px; color: #999; font-style: italic;">
                        (Nessuna firma tecnico)
                    </div>
                }
                <div class="signature-label">Firma Tecnico</div>
            </div>
        </div>
    </div>
}
