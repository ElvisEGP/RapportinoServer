@inherits LayoutComponentBase
@implements IDisposable
@inject NavigationManager Nav
@inject RapportinoServer.Services.AuthStateService AuthState
 <NavMenu />
<div class="page">
   
    <main>

        <article class="content px-4">
            <ErrorBoundary @ref="ErrorBoundaryRef">
                <ChildContent>
                    @Body
                </ChildContent>
                <ErrorContent Context="exception">
                    <div class="alert alert--error">
                        <p>Não foi possível carregar esta página no momento.</p>
                        <button class="btn btn--secondary btn--small" @onclick="Recover">Tentar novamente</button>
                    </div>
                </ErrorContent>
            </ErrorBoundary>
        </article>
    </main>
</div>

@code {
    private ErrorBoundary? ErrorBoundaryRef;

    private void Recover()
    {
        ErrorBoundaryRef?.Recover();
        Nav.NavigateTo(Nav.Uri, forceLoad: false);
    }

    protected override void OnInitialized()
    {
        AuthState.OnAuthStateChanged += HandleAuthStateChanged;
        EnsureAccess();
    }

    protected override void OnParametersSet()
    {
        EnsureAccess();
    }

    private void EnsureAccess()
    {
        var relativePath = "/" + Nav.ToBaseRelativePath(Nav.Uri).Split('?', 2)[0].Trim('/');
        if (relativePath == "//")
            relativePath = "/";

        if (relativePath.Equals("/login", StringComparison.OrdinalIgnoreCase))
            return;

        if (!AuthState.IsAuthenticated)
        {
            var encodedReturnUrl = Uri.EscapeDataString(relativePath == "/" ? "/home" : relativePath);
            Nav.NavigateTo($"/login?returnUrl={encodedReturnUrl}", forceLoad: false);
            return;
        }

        if (!AuthState.CanAccessPath(relativePath))
        {
            Nav.NavigateTo("/home", forceLoad: false);
        }
    }

    private void HandleAuthStateChanged()
    {
        _ = InvokeAsync(StateHasChanged);
    }

    public void Dispose()
    {
        AuthState.OnAuthStateChanged -= HandleAuthStateChanged;
    }
}
